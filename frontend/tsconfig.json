{
  "compilerOptions": {
    // 🔹 Target & libs
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    // 🔹 Module system (Next.js requirement)
    "module": "esnext",
    "moduleResolution": "bundler",
    // 🔹 React / JSX
    "jsx": "react-jsx",
    // 🔹 Strict Type Safety (VERY IMPORTANT)
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    // 🔹 Next.js specific
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    // 🔹 Base URL (CRITICAL)
    "baseUrl": ".",
    // 🔥 PATH ALIASES (FIXED)
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@store/*": [
        "src/store/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@components/*": [
        "src/shared/components/*"
      ],
      "@styles/*": [
        "src/styles/*"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@utils/*": [
        "src/core/utils/*"
      ],
      "@hooks/*": [
        "src/core/hooks/*"
      ]
    },
    // 🔹 Next.js plugin
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  // 🔹 Files included
  "include": [
    "next-env.d.ts",
    "src/**/*",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  // 🔹 Exclusions
  "exclude": [
    "node_modules"
  ]
}
